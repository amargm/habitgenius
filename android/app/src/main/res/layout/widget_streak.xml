<?xml version="1.0" encoding="utf-8"?>
<!--
  Streak Showcase Widget  2×1 (resizable to 2×2)
  Shows top-3 habits by current streak.
  Each row: emoji icon + habit name + streak count + 5 recent-day dots.
  Read-only — tap anywhere opens the app.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/widget_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔥 Streaks"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/streak_open_app"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="Open HabitGenius" />

    </LinearLayout>

    <!-- Row 0 -->
    <LinearLayout
        android:id="@+id/streak_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:id="@+id/streak_icon_0" android:layout_width="22dp" android:layout_height="22dp" android:gravity="center" android:textSize="14sp" />
        <TextView android:id="@+id/streak_name_0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="11sp" android:textColor="?android:attr/textColorPrimary" android:maxLines="1" android:ellipsize="end" android:paddingStart="4dp" android:paddingEnd="4dp" />
        <TextView android:id="@+id/streak_count_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold" android:paddingEnd="4dp" />
        <ImageView android:id="@+id/streak_dot_0_0" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_0_1" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_0_2" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_0_3" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_0_4" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />

    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/streak_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:id="@+id/streak_icon_1" android:layout_width="22dp" android:layout_height="22dp" android:gravity="center" android:textSize="14sp" />
        <TextView android:id="@+id/streak_name_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="11sp" android:textColor="?android:attr/textColorPrimary" android:maxLines="1" android:ellipsize="end" android:paddingStart="4dp" android:paddingEnd="4dp" />
        <TextView android:id="@+id/streak_count_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold" android:paddingEnd="4dp" />
        <ImageView android:id="@+id/streak_dot_1_0" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_1_1" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_1_2" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_1_3" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_1_4" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />

    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/streak_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:id="@+id/streak_icon_2" android:layout_width="22dp" android:layout_height="22dp" android:gravity="center" android:textSize="14sp" />
        <TextView android:id="@+id/streak_name_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="11sp" android:textColor="?android:attr/textColorPrimary" android:maxLines="1" android:ellipsize="end" android:paddingStart="4dp" android:paddingEnd="4dp" />
        <TextView android:id="@+id/streak_count_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold" android:paddingEnd="4dp" />
        <ImageView android:id="@+id/streak_dot_2_0" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_2_1" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_2_2" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_2_3" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />
        <ImageView android:id="@+id/streak_dot_2_4" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="1dp" />

    </LinearLayout>

    <!-- Empty state (no habits with any streak) -->
    <TextView
        android:id="@+id/streak_empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Complete habits to build streaks"
        android:textSize="11sp"
        android:textColor="?android:attr/textColorSecondary"
        android:visibility="gone" />

</LinearLayout>
